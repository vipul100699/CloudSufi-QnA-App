# ── Required ───────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: LangSmith Observability ─────────────────────────────────────────
# Uncomment to enable full LLM call tracing via LangSmith (free tier available).
# Scaling path: enables production-grade observability with zero code changes.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=cloudsufi-doc-qa
